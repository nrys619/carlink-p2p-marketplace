PORT=8787
NODE_ENV=production
CORS_ORIGIN=https://your-domain.example

# OpenAI vision OCR. If omitted, the app keeps working with local fallback analysis.
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4.1-mini

# Optional SMS delivery. If omitted, registration returns a preview code for testing.
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_PHONE=

# Optional direct HTTPS for the bundled Node server.
# In managed platforms such as Vercel, Render, Fly.io, Railway, or a reverse proxy,
# TLS is usually terminated before this Node process and these are not needed.
HTTPS_KEY_PATH=certs/localhost-key.pem
HTTPS_CERT_PATH=certs/localhost.pem
